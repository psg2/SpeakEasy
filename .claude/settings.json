{
  "permissions": {
    "allow": [
      "Bash(mise run lint:*)",
      "Bash(mise run format:*)",
      "Bash(mise run build:*)",
      "Bash(mise run dev:*)",
      "Bash(mise run test:*)",
      "Bash(swift test:*)",
      "Bash(swiftformat:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/install-swift.sh"
          }
        ]
      }
    ]
  }
}